# Neon Postgres connection string.
# Use the pooled connection string for Vercel/serverless runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Optional direct connection for migrations/import scripts.
DATABASE_DIRECT_URL=""

# Public map style. OpenFreeMap is a free/default starting point.
NEXT_PUBLIC_MAP_STYLE_URL="https://tiles.openfreemap.org/styles/liberty"

# Default map center near Houghton, MI. Format: longitude,latitude
NEXT_PUBLIC_DEFAULT_CENTER="-88.5690,47.1211"
NEXT_PUBLIC_DEFAULT_ZOOM="13"

# Parcel API behavior
PARCEL_BBOX_LIMIT="2000"
NEXT_PUBLIC_PARCEL_MIN_ZOOM="13"
NEXT_PUBLIC_PARCEL_VECTOR_TILES="true"
PARCEL_TILE_MIN_ZOOM="13"
API_RATE_LIMIT_PER_MINUTE="240"
API_RATE_LIMIT_DISABLED="false"

# Optional private-app auth.
# Leave APP_AUTH_PASSWORD empty for local/demo open mode.
# Set APP_AUTH_PASSWORD and APP_AUTH_SESSION_SECRET in Vercel for private production use.
# When database-backed account creation is enabled, APP_AUTH_PASSWORD also acts as the workspace invite password.
APP_AUTH_PASSWORD=""
APP_AUTH_SESSION_SECRET=""
APP_AUTH_USERNAME=""
APP_AUTH_USER_ID="private-app-user"
APP_AUTH_USER_EMAIL=""
APP_AUTH_USER_NAME="Private app user"
APP_AUTH_SESSION_TTL_SECONDS="604800"

# App metadata
NEXT_PUBLIC_APP_NAME="Realtor Parcel MVP"
