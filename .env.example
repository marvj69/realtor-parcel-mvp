# Neon Postgres connection string.
# Use the pooled connection string for Vercel/serverless runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Optional direct connection for migrations/import scripts.
DATABASE_DIRECT_URL=""

# Public map style. OpenFreeMap is a free/default starting point.
NEXT_PUBLIC_MAP_STYLE_URL="https://tiles.openfreemap.org/styles/liberty"

# Default map center near Houghton, MI. Format: longitude,latitude
NEXT_PUBLIC_DEFAULT_CENTER="-88.5690,47.1211"
NEXT_PUBLIC_DEFAULT_ZOOM="13"

# Parcel API behavior
PARCEL_BBOX_LIMIT="2000"
NEXT_PUBLIC_PARCEL_MIN_ZOOM="13"

# App metadata
NEXT_PUBLIC_APP_NAME="Realtor Parcel MVP"
